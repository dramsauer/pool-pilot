{
  "name": "Pool Water Balance (Dev)",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "pool-app",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff",
        "mjethwa-streamlit.streamlit-preview"
      ],
      "settings": {
        "streamlitPreview.autoStart": true,
        "streamlitPreview.port": 8501,
        "streamlitPreview.openInSidePanel": true
      }
    }
  },
  "forwardPorts": [8501],
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "postCreateCommand": "sudo chown -R vscode:vscode /app",
  "postStartCommand": "nohup streamlit run Wasserrechner.py --server.headless=true --server.port=8501 > /tmp/streamlit.log 2>&1 &",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "upgradePackages": false,
      "username": "vscode"
    }
  }
}
