{
  "name": "Pool Water Balance (Dev)",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "pool-app",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
      ],
      "settings": {}
    }
  },
  "forwardPorts": [8501],
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "postCreateCommand": "sudo chown -R vscode:vscode /app",
  "postStartCommand": "nohup streamlit run Wasserrechner.py --server.headless=true --server.port=8501 > /tmp/streamlit.log 2>&1 & sleep 2 && echo '🌐 PoolPilot: http://localhost:8501 → Im VS Code: Cmd+Shift+P → Simple Browser: Show'",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "upgradePackages": false,
      "username": "vscode"
    }
  }
}
