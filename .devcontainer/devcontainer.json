{
  "name": "Pool Water Balance (Dev)",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "pool-app",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
      ]
    }
  },
  "mounts": [
    "source=/opt/homebrew/bin/opencode,target=/usr/local/bin/opencode,type=bind",
    "source=${env:HOME}/.config/opencode,target=/home/vscode/.config/opencode,type=bind",
    "source=${env:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,optional=true"
  ],
  "forwardPorts": [8501],
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "upgradePackages": false,
      "username": "vscode"
    }
  }
}
